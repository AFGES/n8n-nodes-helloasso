{
	"name": "@afges/n8n-nodes-helloasso",
	"version": "0.0.3",
	"description": "A node for building integrations with the Helloasso API in n8n.",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Charles LESECQ",
		"email": "charles.lesecq@afges.org"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/AFGES/n8n-nodes-helloasso.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HelloassoOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Helloasso/Helloasso.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
